# Kanonik site kökü (SONDA / OLMADAN). Vercel Production'da ZORUNLU tutun:
# - Site haritası / robots / canonical doğru host için (Google Search Console "URL'ye izin verilmiyor" hatasını önler)
# - Search Console'da doğruladığınız hostname ile birebir aynı olsun (www vs apex tutarlılığı)
# NEXT_PUBLIC_SITE_URL=https://eventseat.de

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service Role Key (admin işlemleri için - RLS bypass)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Ticket e-mail configuration
RESEND_API_KEY=your_resend_api_key
TICKET_EMAIL_FROM="Bilet Ekosistemi <noreply@yourdomain.com>"
# Fiziksel teslimat siparişlerinde admin uyarı e-postası (opsiyonel)
# ADMIN_ORDER_ALERT_EMAIL=admin@yourdomain.com

# Vercel Cron (hatırlatma mailleri - en az 16 karakter)
# CRON_SECRET=your_random_secret_min_16_chars

# Sentry (hata izleme - opsiyonel)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug

# Stripe (ödeme)
# Public key istemcide kullanılabilir; secret key sadece sunucuda kalmalı.
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY=pk_test_xxx
STRIPE_SECRET_KEY=sk_test_xxx
# Opsiyonel: webhook endpoint doğrulaması için
# STRIPE_WEBHOOK_SECRET=whsec_xxx
