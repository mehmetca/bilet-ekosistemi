# Site URL (domain alındığında ekleyin - SEO canonical, OG links)
# NEXT_PUBLIC_SITE_URL=https://yourdomain.com

# Supabase Configuration
NEXT_PUBLIC_SUPABASE_URL=your_supabase_url
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key

# Service Role Key (admin işlemleri için - RLS bypass)
SUPABASE_SERVICE_ROLE_KEY=your_supabase_service_role_key

# Ticket e-mail configuration
RESEND_API_KEY=your_resend_api_key
TICKET_EMAIL_FROM="Bilet Ekosistemi <noreply@yourdomain.com>"

# Vercel Cron (hatırlatma mailleri - en az 16 karakter)
# CRON_SECRET=your_random_secret_min_16_chars

# Sentry (hata izleme - opsiyonel)
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_ORG=your-org-slug
SENTRY_PROJECT=your-project-slug
