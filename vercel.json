{
  "redirects": [
    {
      "source": "/(.*)",
      "has": [{ "type": "host", "value": "eventseat.de" }],
      "destination": "https://www.kurdevents.com/$1",
      "permanent": true
    }
  ],
  "crons": [
    {
      "path": "/api/cron/send-reminders",
      "schedule": "0 9 * * *"
    }
  ]
}